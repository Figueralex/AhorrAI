{
  "expo": {
    "name": "AhorrAI",
    "slug": "AhorrAI",
    "owner": "dumkayt",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "scheme": "ahorrai",
    "android": {
      "package": "com.ahorrai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "f324c3b9-c968-4784-a603-ae256c9c1f9b"
      }
    }
  }
}
